ENV=local_dev

INTELCROP_API_KEY=change-me
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MAX_FIELD_AREA_HA=100
MIN_FIELD_AREA_HA=0.05
ANALYZE_RATE_LIMIT_PER_HOUR=30

CONTRACT_VALIDATION_MODE=warn

ANALYSIS_PROFILE=operational_fast

COMPUTE_TREND_DATA=false
COMPUTE_FIELD_SIGNIFICANCE=false
COMPUTE_NORMALITY_DIAGNOSTICS=false
COMPUTE_VDI=false

GENERATE_RESPONSE_MAP_LAYER=true
GENERATE_INDEX_MAP_LAYERS=false
GENERATE_MAP_SNAPSHOTS=false

DEBUG_ANALYSIS=false
ANALYSIS_TIMING=true

ANALYSIS_JOB_WORKERS=2

DATABASE_URL=postgresql://intellcrop:intellcrop_local_password@localhost:5433/intellcrop
POSTGIS_ENABLED=true

DATABASE_URL=postgresql://intellcrop:intellcrop@localhost:5432/intellcrop
LANDCOVER_LAYER_VERSION=cut_calabria_v1
LANDCOVER_HIGH_CONFIDENCE_COVERAGE=0.75
LANDCOVER_MEDIUM_CONFIDENCE_COVERAGE=0.50
